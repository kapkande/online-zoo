<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="styles/mapPage.css">
    <link rel="stylesheet" href="styles/footer&header.css">
    <%-include('./partials/head')%>
</head>

<body>
    <div class="wrapper">
        <header class="header">
            <%-include('./partials/header')%>
        </header>
        <section class="map">
            <%-include('./partials/svgMap')%>
            <div class="buttons">
                <button class="plus">+</button>
                <button class="minus">-</button>
            </div>
        </section>
        <footer class="footer">
            <%-include('./partials/footer')%>
        </footer>
        <div class="popup">
            <%-include('./partials/popup')%>
        </div>
    </div>
    
    
    <script src="./components/mapPage.js"></script>
</body>

</html>